<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- ═══════════ DISPLAY AREA ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xxl"
        android:paddingEnd="@dimen/spacing_xxl"
        android:paddingTop="48dp">

        <TextView
            android:id="@+id/tvDialedNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:hint="@string/dial_hint"
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/keypad_display_size"
            android:fontFamily="sans-serif-light"
            android:maxLines="1"
            android:ellipsize="start"
            android:letterSpacing="0.05"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvAddContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add to contacts"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:visibility="invisible"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="@dimen/spacing_md"/>

            <TextView
                android:id="@+id/tvClear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="invisible"
                android:padding="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ═══════════ KEYPAD GRID ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md">
            <include layout="@layout/item_keypad_button" android:id="@+id/btn1" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn2" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn3" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md">
            <include layout="@layout/item_keypad_button" android:id="@+id/btn4" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn5" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn6" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md">
            <include layout="@layout/item_keypad_button" android:id="@+id/btn7" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn8" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn9" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xxl">
            <include layout="@layout/item_keypad_button" android:id="@+id/btnStar" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btn0" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <include layout="@layout/item_keypad_button" android:id="@+id/btnHash" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Call Button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/spacing_lg">

            <FrameLayout
                android:id="@+id/btnCall"
                android:layout_width="@dimen/call_button_size"
                android:layout_height="@dimen/call_button_size"
                android:layout_gravity="center"
                android:background="@drawable/bg_call_btn"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_call"
                    android:tint="@color/white"
                    android:contentDescription="@string/cd_call_button"/>
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
